// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - email: string (required) - User email
//   - displayName: string (optional)
//   - role: string (required, enum: ['client', 'admin'])
//   - createdAt: timestamp (required)
//
// Collection: services
// Document ID: {serviceId}
// Fields:
//   - userId: string (required) - Owner UID
//   - type: string (required, enum: ['consultation', 'business_setup', 'product_reg', 'branding', 'growth'])
//   - status: string (required, enum: ['pending', 'processing', 'completed', 'rejected'])
//   - data: map (required) - Specific form data
//   - createdAt: timestamp (required)
//   - updatedAt: timestamp (required)
//
// Collection: services/{serviceId}/messages
// Document ID: {messageId}
// Fields:
//   - serviceId: string (required)
//   - senderId: string (required)
//   - text: string (required)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "2010onlyforyou77@gmail.com" && request.auth.token.email_verified == true));
    }

    function isServiceOwner(serviceId) {
      return isAuthenticated() && get(/databases/$(database)/documents/services/$(serviceId)).data.userId == request.auth.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['client', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidService(data) {
      return data.keys().hasAll(['userId', 'type', 'status', 'data', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['consultation', 'business_setup', 'product_reg', 'branding', 'growth'] &&
             data.status in ['pending', 'processing', 'completed', 'rejected'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['serviceId', 'senderId', 'text', 'createdAt']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 5000 &&
             data.senderId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'client' || isAdmin());
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /services/{serviceId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidService(request.resource.data);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && isValidService(request.resource.data) && request.resource.data.status == resource.data.status);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (isServiceOwner(serviceId) || isAdmin());
        allow create: if isAuthenticated() && (isServiceOwner(serviceId) || isAdmin()) && isValidMessage(request.resource.data);
      }
    }
  }
}
